datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Proxy {
  apiKey      String   @id
  type        String
  destination String?
  port        Int      @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
